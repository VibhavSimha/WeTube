# Server
PORT=8001
NODE_ENV=development

# MongoDB (database name "wetube" is appended automatically)
MONGODB_URI=mongodb://127.0.0.1:27017

# CORS — frontend URL allowed to access the API
CORS_ORIGIN=http://localhost:5173

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary (variable names match the codebase spelling)
COULDINARY_NAME=your_cloudinary_cloud_name
COULDINARY_API_KEY=your_cloudinary_api_key
COULDINARY_API_SECRET=your_cloudinary_api_secret
